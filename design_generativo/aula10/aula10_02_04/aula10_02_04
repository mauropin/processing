PGraphics layer;
PImage foto;
//PFont Ufes;

float ix, iy;

void setup() {
  size(1000, 660);
  pixelDensity(1);
  foto = loadImage("prakaba_DSC_8019.jpg");
  //Ufes = createFont("UfesSans-Bold", 16);
  ix = width/2; iy = 0;
}



void draw() {
   //mostrar a foto original na tela, sempre no inicio do draw
  image(foto, 0, 0, foto.width/3, foto.height/3);
  loadPixels(); //armazenar os valores de cada pixel da foto no array pixels[]
  
  /*
   * crio uma imagem de referência apenas na memoria
   * com a palavra DESIGN descendo
   *
   */
  layer = createGraphics(width, height);
  layer.beginDraw();
  layer.background(0);
  layer.fill(255);  
  //layer.textFont(Ufes);
  layer.textSize(320);
  layer.textAlign(CENTER, CENTER);
  layer.text("Design", ix, iy);
  layer.endDraw();
  layer.loadPixels(); //armazenar os valores dos pixels dessa imagem no array layer.pixels[]
  
  for (int y = 0; y < height; y++) {
    for (int x = 0; x < width; x++) {
      int i = y * width + x;
      color c = layer.get(x, y); //vejo se a cor na imagem de referencia e preta ou branca
      if (c == color(0)) {
        pixels[i] = color(0); //se o pixel de refencia for preto, pinto de preto o pixel da fotografia
      }
    }
  }
  updatePixels();
  
  
  /* 
   * a variavel que controla a posicao do texto
   * vai mudar, a palavra DESIGN vai se deslocar na tela
   */
    
  iy+= 2.5;
  if(iy > height+80) iy = -80;
}
